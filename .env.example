# 🚀 Will Finance 5.0 - Configuração de Ambiente (Versão Nativa)
# Copie este arquivo para .env e configure suas variáveis

# ===============================================
# 🗄️ BANCO DE DADOS
# ===============================================

# SQLite (Desenvolvimento - Padrão Otimizado)
DATABASE_URL="file:./prisma/dev.db"

# PostgreSQL (Produção - Descomente se necessário)
# DATABASE_URL="postgresql://username:password@localhost:5432/will_finance_db"

# ===============================================
# 🔐 AUTENTICAÇÃO E SEGURANÇA  
# ===============================================

# JWT Secrets (MUDE EM PRODUÇÃO!)
JWT_SECRET="will-finance-super-secret-jwt-key-change-in-production-256-bits-minimum"
JWT_REFRESH_SECRET="will-finance-super-secret-refresh-key-change-in-production-256-bits"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="30d"

# Session Secret (MUDE EM PRODUÇÃO!)
SESSION_SECRET="will-finance-session-secret-change-in-production"

# ===============================================
# 🌐 CONFIGURAÇÃO DE SERVIDOR
# ===============================================

# Portas dos serviços
PORT=8080
CLIENT_PORT=5173
AI_PORT=8001
PRISMA_STUDIO_PORT=5555

# URLs base
API_URL="http://localhost:8080"
CLIENT_URL="http://localhost:5173"
AI_SERVICE_URL="http://localhost:8001"

# ===============================================
# 🔌 GOOGLE OAUTH (Opcional)
# ===============================================

# Obtenha em: https://console.developers.google.com
GOOGLE_CLIENT_ID="your-google-client-id.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URL="http://localhost:8080/auth/google/callback"

# ===============================================
# 🤖 SERVIÇO DE IA
# ===============================================

# Configurações do FastAPI
AI_SERVICE_ENABLED=true
AI_MODEL_PATH="./models"
AI_DEBUG=true

# ===============================================
# 📧 EMAIL (Opcional)
# ===============================================

# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Will Finance <noreply@willfinance.com>"

# ===============================================
# 🔄 REDIS (Opcional - Para cache avançado)
# ===============================================

REDIS_URL="redis://localhost:6379"
REDIS_ENABLED=false

# ===============================================
# 📊 MONITORAMENTO E LOGS
# ===============================================

# Nível de log
LOG_LEVEL="debug"
LOG_TO_FILE=true
LOG_TO_CONSOLE=true

# Diretório de logs
LOG_DIR="./logs"

# ===============================================
# 🌍 AMBIENTE
# ===============================================

NODE_ENV="development"
ENVIRONMENT="development"

# ===============================================
# 🔒 CONFIGURAÇÕES DE SEGURANÇA
# ===============================================

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# CORS
CORS_ORIGIN="http://localhost:5173"
CORS_CREDENTIALS=true

# ===============================================
# 🎨 CONFIGURAÇÕES DA APLICAÇÃO
# ===============================================

# Nome da aplicação
APP_NAME="Will Finance 5.0"
APP_VERSION="5.0.0"
APP_DESCRIPTION="Sistema de Gestão Financeira Cyberpunk"

# Configurações de upload
MAX_FILE_SIZE="10MB"
UPLOAD_DIR="./uploads"

# ===============================================
# 🏦 INTEGRAÇÕES BANCÁRIAS (Futuro)
# ===============================================

# Open Banking (quando disponível)
OPEN_BANKING_ENABLED=false
OPEN_BANKING_CLIENT_ID=""
OPEN_BANKING_CLIENT_SECRET=""

# ===============================================
# 📱 PWA E NOTIFICAÇÕES
# ===============================================

# Configurações PWA
PWA_ENABLED=true
NOTIFICATIONS_ENABLED=true

# VAPID Keys (para push notifications)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="mailto:admin@willfinance.com"

# ===============================================
# 🧪 DESENVOLVIMENTO E TESTES
# ===============================================

# Seeds e dados de teste
SEED_DEMO_DATA=true
DEMO_USER_EMAIL="demo@willfinance.com"
DEMO_USER_PASSWORD="demo123"

# Configurações de desenvolvimento
HOT_RELOAD=true
SOURCE_MAPS=true

# ===============================================
# ☁️ DEPLOY (Para produção)
# ===============================================

# URL de produção
PRODUCTION_URL="https://your-domain.com"

# Configurações de CDN
CDN_URL=""
STATIC_URL=""

# Database de produção
# DATABASE_URL="postgresql://user:pass@host:5432/db"

# ===============================================
# 📝 NOTAS DE CONFIGURAÇÃO
# ===============================================

# 1. Para desenvolvimento local, apenas configure:
#    - DATABASE_URL (SQLite já configurado)
#    - JWT_SECRET e SESSION_SECRET (se quiser segurança)
#    - GOOGLE_CLIENT_ID/SECRET (se quiser OAuth)

# 2. Para produção, configure TODOS os secrets:
#    - Mude todos os secrets/passwords
#    - Use PostgreSQL como DATABASE_URL
#    - Configure domínio real em CORS_ORIGIN
#    - Configure email SMTP se necessário

# 3. Serviços opcionais:
#    - Redis: Para cache avançado
#    - Email: Para notificações e recuperação
#    - Google OAuth: Para login social
#    - IA Service: Para funcionalidades ML

# ===============================================
# 🚀 COMANDOS ÚTEIS
# ===============================================

# ./setup.sh         # Configuração inicial
# ./start.sh          # Iniciar todos os serviços  
# ./health.sh         # Verificar saúde do sistema
# ./clean.sh          # Limpeza de cache/dependências
